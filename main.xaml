<Window x:Class="blitz.main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:blitz"
        Title="blitzkrieg" Height="780" Width="540"
        Background="#1e1e22"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar x:Name="head" Grid.Row="0" Minimum="0" Maximum="100" Value="0"/>

        <Border Grid.Row="1" Background="#252529" CornerRadius="6" Margin="16,16,16,0" Padding="20">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="BLITZKRIEG" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="btnru" Content="RU" Tag="ru" Click="swap" Padding="10,5,10,5" FontSize="11" Margin="0,0,6,0"/>
                        <Button x:Name="btnen" Content="EN" Tag="en" Click="swap" Padding="10,5,10,5" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="pos" Text="стартпосы" Foreground="#a0a0a5" FontSize="11" Margin="0,18,0,8"/>
                <Grid>
                    <TextBox x:Name="field" Padding="14,12" FontSize="14" TextChanged="trip" KeyDown="press"/>
                    <TextBlock x:Name="hint" Text="20, 50, 80 -- через пробел или запятую, можно с %." Foreground="#5a5a62" FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button x:Name="go" Content="начать" Click="build" Background="#4a90e2" Padding="22,10" FontSize="13"/>
                    <Button x:Name="cut" Content="очистить" Click="wipe" Padding="16,10" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="16,14,16,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="info" Grid.Column="0" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="stat" Grid.Column="1" Foreground="#6e6e78" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="more" Foreground="#a0a0a5" FontSize="11" Margin="0,5,0,0"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden" Margin="0,14,0,12" Padding="0,0,0,4">
                        <StackPanel x:Name="tabs" Orientation="Horizontal"/>
                    </ScrollViewer>

                    <ItemsControl x:Name="grid" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:stage}">
                                <Border Background="{Binding tint}" CornerRadius="6" Padding="14" Margin="0,0,0,10" Cursor="Hand" MouseLeftButtonUp="pick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21" Background="#1EFFFFFF" VerticalAlignment="Center" Margin="0,0,14,0">
                                            <Grid>
                                                <Grid x:Name="i0" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
                                                    <Ellipse Stroke="White" StrokeThickness="1.7" Width="20" Height="20" Opacity="0.9"/>
                                                    <Ellipse Fill="White" Width="6" Height="6" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.95"/>
                                                </Grid>
                                                <Grid x:Name="i1" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
                                                    <Ellipse Stroke="White" StrokeThickness="1.4" Width="20" Height="20" Opacity="0.35"/>
                                                    <Path Data="M7,5.5 L15.5,10 L7,14.5 Z" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                                                </Grid>
                                                <Grid x:Name="i2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
                                                    <Ellipse Stroke="White" StrokeThickness="1.4" Width="20" Height="20" Opacity="0.35"/>
                                                    <Path Data="M5.5,10.5 L8.5,13.5 L15,7" Stroke="White" StrokeThickness="1.9" Fill="Transparent" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="11" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding text}" Foreground="White" FontWeight="Bold" FontSize="15"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Click="undo" Background="Transparent" BorderThickness="0" Padding="9" VerticalAlignment="Center" Cursor="Hand" ToolTip="вернуть">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="box" Background="#14FFFFFF" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <Path Data="M8.5,7 L4.5,11 L8.5,15 M4.5,11 H11.5 C13.8,11 15.5,12.7 15.5,15 C15.5,17.3 13.8,19 11.5,19 H8" Stroke="White" StrokeThickness="1.5" Fill="Transparent" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform" Opacity="0.85"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="box" Property="Background" Value="#28FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="box" Property="Background" Value="#35FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding rank}" Value="0">
                                        <Setter TargetName="i0" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding rank}" Value="1">
                                        <Setter TargetName="i1" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding rank}" Value="2">
                                        <Setter TargetName="i2" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="3" Margin="16,10,16,12">
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11">
                <Hyperlink NavigateUri="https://github.com/neurodevelop" RequestNavigate="link" TextDecorations="None">
                    <Hyperlink.Style>
                        <Style TargetType="Hyperlink">
                            <Setter Property="Foreground" Value="#5f5f68"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#a0a0a5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Hyperlink.Style>
                    github.com/neurodevelop
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
